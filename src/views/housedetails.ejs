<!DOCTYPE html>
<html lang="en">

<head>
    <title>
        <%= title %>
    </title>
    <%- include("partials/head.ejs") %>
        <script src="/scripts/houseedit.mjs" type="module" defer></script>
</head>

<body>
    <main>
        <%- include("partials/menu.ejs") %>
            <section>
                <span id="pageTitle">
                    &nbsp;&nbsp;<%= title %>
                </span>

                <section>
                    <form method="post">
                        <span class="money" id="totalCost">$1,000,000</span>

                        <label for="title">Title</label>
                        <input id="title" name="title" required pattern="^(?!.*  )[A-Za-z0-9 .,'&\-]{3,30}$" type="text" value="A house title">
                        <span class="error">Must be 3 to 30 characters in length, with no double spaces</span>

                        <label for="companyName">Company</label>
                        <select id="companyName" name="companyName" type="select" required>
                            <option value="" disabled selected>Select a company…</option>
                            <option value="a">a</option>
                            <option value="b" selected>b</option>
                            <option value="c">c</option>
                        </select>
                        <span class="error">Please select a company</span>

                        <label for="rooms">Rooms</label>
                        <input id="rooms" name="rooms" type="text" value="12" required pattern="^(?:[3-9]|1[0-5])$">
                        <span class="error">Rooms must be a whole number from 3 to 15</span>

                        <label for="bathrooms">Bathrooms</label>
                        <input id="bathrooms" name="bathrooms" type="text" value="2" required pattern="^[12]$">
                        <span class="error">Bathrooms must be 1 or 2</span>
                        
                        <label for="garages">Garages</label>
                        <input id="garages" name="garages" type="text" value="2" required pattern="^[12]$">
                        <span class="error">Garages must be 1 or 2</span>

                        <label for="floorAreaSqm">Floor area sqm</label>
                        <input id="floorAreaSqm" name="floorAreaSqm" type="text" value="400" required pattern="^(?:[2-7][0-9]{2}|800)$">
                        <span class="error">Floor area must be 200–800 sqm</span>

                        <label for="storyCount">Stories</label>
                        <input id="storyCount" name="storyCount" type="text" value="2" required pattern="^[12]$">
                        <span class="error">Stories must be 1 or 2</span>

                        <label>Extras</label>
                        <div class="checkbox-row">
                            <div><input id="builtIns" name="builtIns" type="checkbox">Built-ins</div>
                            <div><input id="doubleGlazing" name="doubleGlazing" type="checkbox">Double Glazing Windows
                            </div>
                            <div><input id="solarPanels" name="solarPanel" type="checkbox">Solar Panel Installation
                                (standard)</div>
                        </div>
                        <button type="submit" value="Save">Save</button>
                    </form>
                </section>
            </section>



            <footer>
                <span>© 2026 Uptown I.T. All rights reserved.</span> <span>Version: <%= ver %></span>
            </footer>
    </main>
</body>

</html>